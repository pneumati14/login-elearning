# ─────────────────────────────────────────────────────────────────────
# login — e-learning platform · local development environment
#
# Copy this file to .env before starting the stack:
#     cp .env.example .env
#
# .env is git-ignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────

# Compose project name — isolates containers, networks and volumes.
# Give staging/production a different value so they can coexist.
COMPOSE_PROJECT_NAME=login-elearning

# ── Application ──────────────────────────────────────────────────────
# Symfony environment: dev | staging | prod
APP_ENV=dev
# Symfony application secret. Generate a unique value per environment:
#     openssl rand -hex 16
APP_SECRET=change-me-in-every-environment

# Vue.js frontend
NODE_ENV=development
# Base URL the frontend uses to reach the API (proxied by Caddy).
VITE_API_URL=/api

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=elearning
POSTGRES_USER=elearning
POSTGRES_PASSWORD=change-me-local-dev
# Host port for connecting a database client during development.
POSTGRES_PORT=5432

# ── Caddy reverse proxy ──────────────────────────────────────────────
# Domain Caddy serves. Use "localhost" for local development; Caddy then
# issues a certificate from its own internal CA. For a public domain it
# obtains a real Let's Encrypt certificate automatically.
SITE_ADDRESS=localhost
# Certificate served for SNI-less connections (e.g. opening the site by
# raw IP). Keep "localhost" for local dev; match SITE_ADDRESS otherwise.
DEFAULT_SNI=localhost
# Contact email for Let's Encrypt / ACME — required for public domains.
ACME_EMAIL=
HTTP_PORT=80
HTTPS_PORT=443

# ── Development service ports ────────────────────────────────────────
# Vite dev server, reachable at http://localhost:<port>
FRONTEND_PORT=5173
