# ─────────────────────────────────────────────────────────────────────
# login — e-learning platform · PRODUCTION environment
#
# Copy to production/.env and fill in real values:
#     cp production/.env.example production/.env
#
# production/.env is git-ignored — never commit real secrets.
# Prefer a secrets manager over a plain file for production credentials.
# ─────────────────────────────────────────────────────────────────────

# Distinct project name so production can run alongside other environments.
COMPOSE_PROJECT_NAME=login-elearning-production

# ── Application ──────────────────────────────────────────────────────
APP_ENV=prod
# Generate a unique value:  openssl rand -hex 16
APP_SECRET=CHANGE_ME

NODE_ENV=production
VITE_API_URL=/api

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=elearning
POSTGRES_USER=elearning
# Use a strong, unique password.
POSTGRES_PASSWORD=CHANGE_ME

# ── Caddy reverse proxy ──────────────────────────────────────────────
# Public production domain(s) — Caddy obtains a TLS certificate for each.
# Multiple hostnames may be comma-separated, e.g. "example.com, www.example.com".
SITE_ADDRESS=elearning.example.com
# Certificate served when a client connects without SNI (e.g. raw IP).
DEFAULT_SNI=elearning.example.com
ACME_EMAIL=ops@example.com
HTTP_PORT=80
HTTPS_PORT=443
