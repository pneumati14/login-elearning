# ─────────────────────────────────────────────────────────────────────
# login — e-learning platform · STAGING environment (template)
#
# Copy to staging/.env and fill in the secrets:
#     cp staging/.env.example staging/.env
#
# staging/.env is git-ignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────

# Distinct project name → separate containers, network and DB volume.
COMPOSE_PROJECT_NAME=login-elearning-staging

# ── Application ──────────────────────────────────────────────────────
APP_ENV=staging
# Generate a unique value:  openssl rand -hex 16
APP_SECRET=CHANGE_ME

NODE_ENV=staging
VITE_API_URL=/api

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=elearning
POSTGRES_USER=elearning
# Use a strong, unique password:  openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME

# ── Upload storage ───────────────────────────────────────────────────
# Separate from production so test uploads never mix with live data.
STORAGE_DIR=./storage-staging

# ── Caddy reverse proxy ──────────────────────────────────────────────
# Staging runs alongside production on the same host. Production owns
# ports 80/443; staging publishes HTTPS only, on HTTPS_PORT.
SITE_ADDRESS=https://178.105.197.49
DEFAULT_SNI=178.105.197.49
ACME_EMAIL=
HTTPS_PORT=8443
